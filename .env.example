# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend audience IDs (create in Resend dashboard)
RESEND_NEWSLETTER_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RESEND_WAITLIST_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Plain.com widget app ID — get from Plain dashboard > Settings > Chat Widget
PLAIN_APP_ID=xxxxxxxxxx

# Download URL — direct link to latest Lagos DMG
# Update this on each release
LAGOS_DOWNLOAD_URL=https://github.com/rKalb/lagos-releases/releases/latest/download/Lagos.dmg

# Discord invite link
DISCORD_INVITE_URL=https://discord.gg/PLACEHOLDER
