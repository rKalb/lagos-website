---
interface Props {
  class?: string;
  padding?: 'sm' | 'md' | 'lg';
}

const {
  class: className = '',
  padding = 'md',
} = Astro.props;

const paddingClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};
---

<div
  class={`rounded-xl border ${paddingClasses[padding]} ${className}`}
  style="background-color: var(--color-surface); border-color: var(--color-border); box-shadow: 0 1px 3px 0 rgba(0,0,0,0.07), 0 1px 2px -1px rgba(0,0,0,0.06);"
>
  <slot />
</div>
