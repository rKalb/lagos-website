---
interface Props {
  size?: 'md' | 'lg';
  label?: string;
  class?: string;
}

const {
  size = 'lg',
  label = 'Download for Mac — Free',
  class: className = '',
} = Astro.props;

const downloadUrl = import.meta.env.LAGOS_DOWNLOAD_URL ?? '#download';

const sizeClasses = {
  md: 'px-6 py-3 text-sm gap-2',
  lg: 'px-8 py-4 text-base gap-2.5',
};
---

<div class={`flex flex-col items-start gap-2 ${className}`}>
  <a
    href={downloadUrl}
    class={`inline-flex items-center rounded-xl font-semibold no-underline transition-all hover:opacity-90 active:scale-95 shadow-sm ${sizeClasses[size]}`}
    style="background-color: var(--color-accent-500); color: var(--color-warm-900);"
    aria-label="Download Lagos for Mac"
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 20 20"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M10 14.5L4.5 9H8V3h4v6h3.5L10 14.5z" />
      <rect x="3" y="16" width="14" height="2" rx="1" />
    </svg>
    {label}
  </a>
  <p class="text-xs" style="color: var(--color-text-muted);">
    macOS 13 Ventura or later &bull; Apple Silicon &amp; Intel &bull; Free
  </p>
</div>
