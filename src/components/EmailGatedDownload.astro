---
import { getLatestDownloadUrl } from '../lib/version';

interface Props {
  size?: 'md' | 'lg';
  class?: string;
  theme?: 'light' | 'dark';
  href?: string;
}

const {
  size = 'lg',
  class: className = '',
  theme = 'light',
  href,
} = Astro.props;

const downloadUrl =
  href ??
  import.meta.env.LAGOS_DOWNLOAD_URL ??
  (await getLatestDownloadUrl()) ??
  'https://github.com/rKalb/lagos-releases/releases/latest';

const isDark = theme === 'dark';

const inputStyle = isDark
  ? 'background-color: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); color: var(--color-warm-100);'
  : 'background-color: var(--color-bg); border-color: var(--color-border); color: var(--color-text);';

const hintColor = isDark ? 'color: var(--color-warm-400);' : 'color: var(--color-text-muted);';
const subtextColor = isDark ? 'color: var(--color-warm-500);' : 'color: var(--color-text-muted);';

const sizeClasses = {
  md: { input: 'px-3 py-2 text-sm', button: 'px-4 py-2 text-sm', link: 'px-6 py-3 text-sm' },
  lg: { input: 'px-4 py-2.5 text-sm', button: 'px-5 py-2.5 text-sm', link: 'px-8 py-4 text-base' },
};
---

<div class={`download-gate ${className}`} data-download-url={downloadUrl}>
  <div class="download-gate-form flex flex-col gap-2">
    <p class="text-xs mb-1" style={hintColor}>
      Enter your email to download — we'll keep you updated on new releases.
    </p>
    <div class="flex flex-col sm:flex-row gap-2">
      <input
        type="email"
        placeholder="you@example.com"
        required
        autocomplete="email"
        class={`download-gate-email flex-1 ${sizeClasses[size].input} rounded-lg border`}
        style={`${inputStyle} outline: none;`}
      />
      <button
        type="button"
        class={`download-gate-submit inline-flex items-center justify-center gap-2 ${sizeClasses[size].button} rounded-lg font-semibold no-underline transition-all hover:opacity-90 active:scale-95 whitespace-nowrap`}
        style="background-color: var(--color-accent-500); color: var(--color-warm-900);"
      >
        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10 14.5L4.5 9H8V3h4v6h3.5L10 14.5z"/>
          <rect x="3" y="16" width="14" height="2" rx="1"/>
        </svg>
        Download free
      </button>
    </div>
    <p class="download-gate-error text-xs hidden" style="color: #dc2626;"></p>
  </div>
  <div class="download-gate-success flex flex-col items-start gap-2" style="display: none;">
    <a
      href={downloadUrl}
      class={`inline-flex items-center gap-2.5 ${sizeClasses[size].link} rounded-xl font-semibold no-underline transition-all hover:opacity-90 active:scale-95 shadow-sm`}
      style="background-color: var(--color-accent-500); color: var(--color-warm-900);"
      aria-label="Download Lagos for Mac"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M10 14.5L4.5 9H8V3h4v6h3.5L10 14.5z"/>
        <rect x="3" y="16" width="14" height="2" rx="1"/>
      </svg>
      Download Lagos for Mac
    </a>
    <p class="text-xs" style={subtextColor}>
      macOS 13 Ventura or later &bull; Apple Silicon &amp; Intel &bull; Free
    </p>
  </div>
</div>

<style>
  .download-gate-form { display: flex; }
  .download-gate-success { display: none !important; }
  .download-gate.is-unlocked .download-gate-form { display: none; }
  .download-gate.is-unlocked .download-gate-success { display: flex !important; }
</style>

<script>
  document.querySelectorAll<HTMLDivElement>('.download-gate').forEach(gate => {
    const emailInput = gate.querySelector<HTMLInputElement>('.download-gate-email');
    const submitBtn = gate.querySelector<HTMLButtonElement>('.download-gate-submit');
    const errorEl = gate.querySelector<HTMLParagraphElement>('.download-gate-error');

    if (!emailInput || !submitBtn) return;

    const handleSubmit = async () => {
      const email = emailInput.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (errorEl) {
          errorEl.textContent = 'Please enter a valid email address.';
          errorEl.classList.remove('hidden');
        }
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';
      if (errorEl) errorEl.classList.add('hidden');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, type: 'newsletter' }),
        });

        if (res.ok) {
          gate.classList.add('is-unlocked');
          const url = gate.dataset.downloadUrl;
          if (url) window.location.href = url;
        } else {
          throw new Error('Failed');
        }
      } catch {
        if (errorEl) {
          errorEl.textContent = 'Something went wrong. Please try again.';
          errorEl.classList.remove('hidden');
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Download free';
      }
    };

    submitBtn.addEventListener('click', handleSubmit);
    emailInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        handleSubmit();
      }
    });
  });
</script>
