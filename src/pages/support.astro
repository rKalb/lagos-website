---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
---

<BaseLayout
  title="Support"
  description="Get help with Lagos. Browse common questions or reach out to the team."
>
  <section class="pt-20 pb-12 px-4 sm:px-6 lg:px-8 text-center">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl font-bold mb-4" style="color: var(--color-text);">How can we help?</h1>
      <p class="text-lg" style="color: var(--color-text-muted);">
        Browse the docs, check common questions, or reach out directly.
      </p>
    </div>
  </section>

  <!-- Quick links -->
  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl grid sm:grid-cols-3 gap-6">
      <a href="/getting-started" class="no-underline">
        <Card class="text-center hover:border-amber-400 transition-colors" style="cursor: pointer;">
          <div class="text-3xl mb-3" aria-hidden="true">📖</div>
          <h2 class="text-base font-semibold mb-1" style="color: var(--color-text);">Documentation</h2>
          <p class="text-sm" style="color: var(--color-text-muted);">Setup guides, engine docs, and how-to articles</p>
        </Card>
      </a>
      <a href="/faq" class="no-underline">
        <Card class="text-center hover:border-amber-400 transition-colors" style="cursor: pointer;">
          <div class="text-3xl mb-3" aria-hidden="true">💬</div>
          <h2 class="text-base font-semibold mb-1" style="color: var(--color-text);">FAQ</h2>
          <p class="text-sm" style="color: var(--color-text-muted);">Quick answers to the most common questions</p>
        </Card>
      </a>
      <a href={import.meta.env.DISCORD_INVITE_URL ?? 'https://discord.gg/PLACEHOLDER'} target="_blank" rel="noopener noreferrer" class="no-underline">
        <Card class="text-center hover:border-amber-400 transition-colors" style="cursor: pointer;">
          <div class="text-3xl mb-3" aria-hidden="true">👾</div>
          <h2 class="text-base font-semibold mb-1" style="color: var(--color-text);">Discord</h2>
          <p class="text-sm" style="color: var(--color-text-muted);">Community chat, help, and feature discussions</p>
        </Card>
      </a>
    </div>
  </section>

  <!-- Contact / Plain widget placeholder -->
  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-xl text-center">
      <h2 class="text-2xl font-bold mb-3" style="color: var(--color-text);">Contact support</h2>
      <p class="text-sm mb-6" style="color: var(--color-text-muted);">
        Can't find what you're looking for? Send us a message and we'll get back to you.
      </p>
      <a
        href="mailto:support@trylagos.app"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm no-underline hover:opacity-90 transition-opacity"
        style="background-color: var(--color-accent-500); color: var(--color-warm-900);"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M2 3h12a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm0 1.5V12h12V4.5L8 9 2 4.5zm0-1L8 8l6-4.5H2z"/>
        </svg>
        Email support
      </a>
      <p class="text-xs mt-4" style="color: var(--color-text-muted);">
        Or use the chat widget in the bottom-right corner of this page.
      </p>
    </div>
  </section>

  <!-- Plain.com chat widget — embed snippet goes here -->
  <!-- Replace PLAIN_APP_ID with your actual Plain app ID from the Plain dashboard -->
  <script is:inline>
    // Plain.com chat widget
    // Replace "PLAIN_APP_ID" with your actual app ID from Plain dashboard > Settings > Chat Widget
    // (function(p,l,a,i,n) { ... }('PLAIN_APP_ID', ...));
    // TODO: Add Plain widget embed snippet here
  </script>
</BaseLayout>
