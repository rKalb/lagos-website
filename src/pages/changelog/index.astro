---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = (await getCollection('changelog'))
  .sort((a, b) => b.data.releaseDate.valueOf() - a.data.releaseDate.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Changelog"
  description="Release history for Lagos — every version, every improvement."
>
  <section class="pt-20 pb-6 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl font-bold mb-3" style="color: var(--color-text);">Changelog</h1>
      <p style="color: var(--color-text-muted);">A record of every Lagos release.</p>
    </div>
  </section>

  <section class="py-10 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <ol class="relative border-l-2 pl-8 space-y-12 list-none" style="border-color: var(--color-border);">
        {entries.map(async (entry) => {
          const { Content } = await entry.render();
          return (
            <li class="relative">
              <!-- Timeline dot -->
              <span
                class="absolute -left-[1.35rem] top-1.5 w-4 h-4 rounded-full border-2"
                style="background-color: var(--color-accent-500); border-color: var(--color-bg);"
                aria-hidden="true"
              ></span>

              <time
                datetime={entry.data.releaseDate.toISOString()}
                class="text-xs uppercase tracking-widest"
                style="color: var(--color-text-muted);"
              >
                {formatDate(entry.data.releaseDate)}
              </time>

              <div class="flex items-center gap-3 mt-1 mb-3">
                <h2 class="text-xl font-bold" style="color: var(--color-text);">{entry.data.title}</h2>
                <span
                  class="text-xs font-mono px-2 py-0.5 rounded"
                  style="background-color: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);"
                >
                  v{entry.data.version}
                </span>
              </div>

              {entry.data.highlights.length > 0 && (
                <ul class="space-y-1 text-sm mb-4" style="color: var(--color-text-muted);">
                  {entry.data.highlights.map((h: string) => (
                    <li class="flex items-start gap-2">
                      <span style="color: var(--color-accent-600);" aria-hidden="true">•</span>
                      {h}
                    </li>
                  ))}
                </ul>
              )}

              <div class="prose text-sm">
                <Content />
              </div>
            </li>
          );
        })}
      </ol>
    </div>
  </section>
</BaseLayout>
