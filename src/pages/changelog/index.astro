---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllReleases } from '../../lib/version';

const releases = await getAllReleases();

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

/**
 * Parse GitHub release markdown into a clean list of changes.
 * Strips the repeated header/installation boilerplate.
 */
function parseChanges(body: string): string[] {
  const lines = body.split('\n');
  const changes: string[] = [];
  for (const line of lines) {
    const trimmed = line.trim();
    // Skip headers, empty lines, and installation boilerplate
    if (!trimmed) continue;
    if (trimmed.startsWith('#')) continue;
    if (trimmed.startsWith('---')) continue;
    if (/^(installation|notes)/i.test(trimmed)) continue;
    if (/download.*\.dmg/i.test(trimmed)) continue;
    if (/open the dmg/i.test(trimmed)) continue;
    if (/launch lagos/i.test(trimmed)) continue;
    if (/drag lagos/i.test(trimmed)) continue;
    if (/right-click/i.test(trimmed)) continue;
    if (/grant microphone/i.test(trimmed)) continue;
    if (/apple silicon only/i.test(trimmed)) continue;
    if (/existing users will receive/i.test(trimmed)) continue;
    if (/signed and notarized/i.test(trimmed)) continue;
    if (/ad-hoc signed/i.test(trimmed)) continue;
    if (/^\d+\.\s/.test(trimmed)) continue; // numbered install steps

    // Extract list items
    const match = trimmed.match(/^[-*]\s+(.+)/);
    if (match) {
      changes.push(match[1]);
    }
  }
  return changes;
}
---

<BaseLayout
  title="Changelog"
  description="Release history for Lagos — every version, every improvement."
>
  <section class="pt-20 pb-6 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-4xl font-bold mb-3" style="color: var(--color-text);">Changelog</h1>
      <p style="color: var(--color-text-muted);">
        A record of every Lagos release — pulled directly from
        <a
          href="https://github.com/rKalb/lagos-releases/releases"
          class="no-underline hover:underline"
          style="color: var(--color-link);"
          target="_blank"
          rel="noopener noreferrer"
        >GitHub Releases</a>.
      </p>
    </div>
  </section>

  <section class="py-10 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      {releases.length === 0 ? (
        <p style="color: var(--color-text-muted);">
          Unable to load releases. Check
          <a href="https://github.com/rKalb/lagos-releases/releases" target="_blank" rel="noopener noreferrer" style="color: var(--color-link);">
            GitHub
          </a>
          for the latest versions.
        </p>
      ) : (
        <ol class="relative border-l-2 pl-8 space-y-12 list-none" style="border-color: var(--color-border);">
          {releases.map((release) => {
            const changes = parseChanges(release.body);
            return (
              <li class="relative">
                {/* Timeline dot */}
                <span
                  class="absolute -left-[1.35rem] top-1.5 w-4 h-4 rounded-full border-2"
                  style="background-color: var(--color-accent-500); border-color: var(--color-bg);"
                  aria-hidden="true"
                ></span>

                <time
                  datetime={release.publishedAt}
                  class="text-xs uppercase tracking-widest"
                  style="color: var(--color-text-muted);"
                >
                  {formatDate(release.publishedAt)}
                </time>

                <div class="flex flex-wrap items-center gap-3 mt-1 mb-3">
                  <h2 class="text-xl font-bold" style="color: var(--color-text);">{release.title}</h2>
                  <span
                    class="text-xs font-mono px-2 py-0.5 rounded"
                    style="background-color: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);"
                  >
                    {release.tag}
                  </span>
                  {release.dmgUrl && (
                    <a
                      href={release.dmgUrl}
                      class="text-xs font-medium no-underline hover:underline"
                      style="color: var(--color-link);"
                    >
                      Download .dmg
                    </a>
                  )}
                </div>

                {changes.length > 0 && (
                  <ul class="space-y-1.5 text-sm" style="color: var(--color-text-muted);">
                    {changes.map((change) => (
                      <li class="flex items-start gap-2">
                        <span style="color: var(--color-accent-600);" aria-hidden="true">•</span>
                        <span>{change}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            );
          })}
        </ol>
      )}
    </div>
  </section>
</BaseLayout>
