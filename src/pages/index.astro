---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailGatedDownload from '../components/EmailGatedDownload.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<style>
  /* Waveform bar animation */
  @keyframes wave {
    0%, 100% { transform: scaleY(0.3); }
    50% { transform: scaleY(1); }
  }
  .bar { animation: wave 0.9s ease-in-out infinite; transform-origin: bottom; }
  .bar:nth-child(1)  { animation-delay: 0.00s; }
  .bar:nth-child(2)  { animation-delay: 0.08s; }
  .bar:nth-child(3)  { animation-delay: 0.16s; }
  .bar:nth-child(4)  { animation-delay: 0.24s; }
  .bar:nth-child(5)  { animation-delay: 0.32s; }
  .bar:nth-child(6)  { animation-delay: 0.40s; }
  .bar:nth-child(7)  { animation-delay: 0.48s; }
  .bar:nth-child(8)  { animation-delay: 0.56s; }
  .bar:nth-child(9)  { animation-delay: 0.64s; }
  .bar:nth-child(10) { animation-delay: 0.72s; }
  .bar:nth-child(11) { animation-delay: 0.80s; }
  .bar:nth-child(12) { animation-delay: 0.88s; }

  @media (prefers-reduced-motion: reduce) {
    .bar { animation: none; transform: scaleY(0.6); }
  }

  /* Typewriter cursor blink */
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  .cursor { animation: blink 1s step-end infinite; }
</style>

<BaseLayout title="Lagos">

  <!-- ── Hero ── -->
  <section
    class="relative overflow-hidden pt-20 pb-0 px-4 sm:px-6 lg:px-8"
    style="background: radial-gradient(ellipse 90% 60% at 50% 0%, rgba(251,191,36,0.18) 0%, transparent 65%), var(--color-bg);"
  >
    <div class="mx-auto max-w-3xl text-center">

      <!-- Beta promo badge -->
      <a
        href="/pricing"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold mb-8 border no-underline transition-opacity hover:opacity-80"
        style="background-color: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.3); color: #059669;"
      >
        <span
          class="inline-block w-1.5 h-1.5 rounded-full animate-pulse"
          style="background-color: #10b981;"
          aria-hidden="true"
        ></span>
        Join the beta by March 31 — get 2 years of Pro free
        <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true" class="opacity-50">
          <path d="M4.5 3L7.5 6L4.5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </a>

      <h1
        class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-none mb-6"
        style="color: var(--color-text); letter-spacing: -0.03em;"
      >
        Talk instead<br />of type.
      </h1>

      <p class="text-xl leading-relaxed mb-10 mx-auto max-w-lg" style="color: var(--color-text-muted);">
        Instant voice dictation for Mac. Hold a keyboard shortcut, speak, release — your words appear wherever you're typing.
      </p>

      <div class="flex justify-center mb-16">
        <EmailGatedDownload size="lg" />
      </div>
    </div>

    <!-- macOS App Mockup -->
    <div
      class="mx-auto max-w-2xl relative"
      aria-label="Lagos app demo showing voice recording interface"
    >
      <!-- Subtle glow behind mockup -->
      <div
        class="absolute inset-0 -z-10 blur-3xl"
        style="background: radial-gradient(ellipse 70% 50% at 50% 60%, rgba(245,158,11,0.12) 0%, transparent 80%);"
        aria-hidden="true"
      ></div>

      <!-- macOS window -->
      <div
        class="rounded-2xl overflow-hidden border"
        style="border-color: rgba(0,0,0,0.12); box-shadow: 0 0 0 1px rgba(255,255,255,0.6) inset, 0 20px 60px -10px rgba(0,0,0,0.18), 0 4px 16px -4px rgba(0,0,0,0.12);"
      >
        <!-- Title bar -->
        <div
          class="flex items-center gap-2 px-4 py-3 border-b"
          style="background: linear-gradient(180deg, #e8e5e0 0%, #ddd8d0 100%); border-color: rgba(0,0,0,0.12);"
        >
          <span class="w-3 h-3 rounded-full" style="background:#ff5f57; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.15);" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full" style="background:#ffbd2e; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.15);" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full" style="background:#28c840; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.15);" aria-hidden="true"></span>
          <span class="flex-1 text-center text-xs font-medium" style="color:#6b6460;">Cursor — project/main.py</span>
        </div>

        <!-- Editor with Lagos popover overlay -->
        <div class="relative" style="background:#1e1b18;">

          <!-- Fake code lines for context -->
          <div class="px-6 pt-5 pb-32 font-mono text-xs leading-relaxed select-none" aria-hidden="true">
            <div class="flex gap-4 mb-1"><span style="color:#4a4540;">1</span><span style="color:#7a6f63;">def <span style="color:#c9aa71;">sort_users</span><span style="color:#e0d9cf;">(users: list[dict]) -&gt; list[dict]:</span></span></div>
            <div class="flex gap-4 mb-1"><span style="color:#4a4540;">2</span><span style="color:#7a6f63;">&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#9b8b7a;">"""</span></span></div>
            <div class="flex gap-4 mb-1"><span style="color:#4a4540;">3</span><span style="color:#9b8b7a;">&nbsp;&nbsp;&nbsp;&nbsp;<span class="opacity-60">Sort users by last login date...</span></span></div>
            <div class="flex gap-4 mb-1"><span style="color:#4a4540;">4</span><span style="color:#9b8b7a;">&nbsp;&nbsp;&nbsp;&nbsp;<span class="opacity-40">▌</span></span></div>
          </div>

          <!-- Lagos recording popover -->
          <div
            class="absolute bottom-4 right-4 rounded-2xl overflow-hidden w-72"
            style="background:rgba(30,27,24,0.96); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 0.5px rgba(255,255,255,0.05) inset; backdrop-filter: blur(16px);"
            role="presentation"
          >
            <!-- Popover header -->
            <div class="flex items-center justify-between px-4 pt-4 pb-2">
              <div class="flex items-center gap-2">
                <span
                  class="w-2 h-2 rounded-full"
                  style="background:#f59e0b; box-shadow: 0 0 6px rgba(245,158,11,0.7);"
                  aria-hidden="true"
                ></span>
                <span class="text-xs font-semibold" style="color:rgba(255,255,255,0.85);">Recording</span>
              </div>
              <span class="text-xs font-mono" style="color:rgba(255,255,255,0.3);">⌘⌃</span>
            </div>

            <!-- Waveform -->
            <div class="flex items-end justify-center gap-1 px-4 py-3" aria-hidden="true" style="height:52px;">
              {Array.from({ length: 12 }).map((_, i) => (
                <div
                  class="bar rounded-full"
                  style={`width:3px; height:${[14,22,36,28,42,32,18,40,24,34,20,16][i % 12]}px; background:var(--color-accent-500); opacity:0.9;`}
                ></div>
              ))}
            </div>

            <!-- Transcription text -->
            <div class="px-4 pb-3">
              <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.7);">
                "Sort users by last login date, most recent first…"<span class="cursor" style="color:var(--color-accent-400);">|</span>
              </p>
            </div>

            <!-- Bottom hint -->
            <div
              class="flex items-center justify-center gap-1.5 px-4 py-2.5 text-xs border-t"
              style="border-color:rgba(255,255,255,0.06); color:rgba(255,255,255,0.3);"
            >
              <span>Release</span>
              <kbd
                class="px-1.5 py-0.5 rounded font-mono text-xs"
                style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); color:rgba(255,255,255,0.5);"
              >⌘⌃</kbd>
              <span>to transcribe</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Social proof / integrations bar ── -->
  <section class="py-12 border-y mt-16" style="border-color: var(--color-border);">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
        Works in every app you use
      </p>
      <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-3" aria-label="Compatible applications">
        {['VS Code', 'Cursor', 'Notion', 'Chrome', 'Slack', 'Mail', 'Obsidian', 'Xcode'].map(app => (
          <span class="text-sm font-medium" style="color: var(--color-warm-500);">{app}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Features overview ── -->
  <section class="py-28 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text); letter-spacing: -0.02em;">Built for how you think</h2>
        <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-muted);">
          No subscriptions. No account. No friction. Hold, speak, release.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          {
            title: 'Instant, zero setup',
            desc: 'Uses Apple\'s built-in Speech framework. Works the moment you install it — no API keys, no configuration.',
            icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
          },
          {
            title: 'Local AI accuracy',
            desc: 'WhisperKit runs entirely on your device via Core ML. As low as ~1% word error rate with the Turbo model. 100% private — no audio leaves your Mac.',
            icon: `<rect x="4" y="4" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.75" fill="none"/><path d="M9 9h6M9 12h6M9 15h4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>`,
          },
          {
            title: 'Privacy first',
            desc: 'Audio is never stored on disk. Local engines stay off the network entirely. You choose exactly where your voice goes.',
            icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
          },
          {
            title: 'Multi-language',
            desc: 'Auto-detect or choose from 12 built-in languages including English, Spanish, French, German, Japanese, Chinese, and more.',
            icon: `<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75" fill="none"/><path d="M2 12h20M12 3a13 13 0 0 1 0 18M12 3a13 13 0 0 0 0 18" stroke="currentColor" stroke-width="1.75" fill="none"/>`,
          },
        ].map(f => (
          <div
            class="rounded-xl border p-6"
            style="background-color: var(--color-surface); border-color: var(--color-border); box-shadow: 0 1px 3px 0 rgba(0,0,0,0.07), 0 1px 2px -1px rgba(0,0,0,0.06);"
          >
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
              style="background-color: var(--color-warm-200); color: var(--color-warm-800);"
              aria-hidden="true"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" set:html={f.icon} />
            </div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-text);">{f.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Engine levels ── -->
  <section class="py-28 px-4 sm:px-6 lg:px-8" style="background-color: var(--color-surface);">
    <div class="mx-auto max-w-3xl">
      <div class="text-center mb-14">
        <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text); letter-spacing: -0.02em;">Your level of control</h2>
        <p class="text-lg" style="color: var(--color-text-muted);">
          From instant built-in to cloud-grade. Start where you are, upgrade when you want.
        </p>
      </div>

      <div class="space-y-3">
        {[
          {
            level: '1',
            name: 'Apple Speech',
            badge: 'Built-in · Zero setup',
            badgeBg: '#d1fae5',
            badgeColor: '#065f46',
            desc: 'macOS Speech Recognition. Instant transcription, works offline, ~8% word error rate.',
            accentBg: '#d1fae5',
            accentColor: '#059669',
          },
          {
            level: '2',
            name: 'WhisperKit — Local AI',
            badge: 'Recommended',
            badgeBg: '#fef3c7',
            badgeColor: '#92400e',
            desc: 'OpenAI Whisper on-device via Core ML. Two models: Standard (~150 MB, ~5% WER) or Turbo (~1.5 GB, ~1% WER). Completely private.',
            accentBg: '#fef3c7',
            accentColor: '#d97706',
          },
          {
            level: '3',
            name: 'Lagos Pro Cloud',
            badge: 'Coming soon',
            badgeBg: '#e0e7ff',
            badgeColor: '#3730a3',
            desc: 'Managed cloud transcription. No API keys required. Best accuracy, zero model management.',
            accentBg: '#e0e7ff',
            accentColor: '#4f46e5',
          },
          {
            level: '4',
            name: 'Bring Your Own Key',
            badge: 'Power users',
            badgeBg: 'var(--color-warm-200)',
            badgeColor: 'var(--color-warm-700)',
            desc: 'Connect OpenAI, Deepgram, AssemblyAI, Google Cloud, or Wispr Flow. Full control over quality and cost.',
            accentBg: 'var(--color-warm-200)',
            accentColor: 'var(--color-warm-700)',
          },
        ].map(e => (
          <div
            class="flex items-start gap-4 p-5 rounded-xl border"
            style="background-color: var(--color-bg); border-color: var(--color-border); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);"
          >
            <div
              class="shrink-0 w-9 h-9 rounded-lg flex items-center justify-center text-sm font-bold"
              style={`background-color: ${e.accentBg}; color: ${e.accentColor};`}
              aria-label={`Level ${e.level}`}
            >
              {e.level}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1.5">
                <h3 class="text-sm font-semibold" style="color: var(--color-text);">{e.name}</h3>
                <span
                  class="text-xs font-medium px-2 py-0.5 rounded-full"
                  style={`background-color: ${e.badgeBg}; color: ${e.badgeColor};`}
                >
                  {e.badge}
                </span>
              </div>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href="/features" class="text-sm font-medium no-underline hover:underline" style="color: var(--color-link);">
          Compare all engines in detail →
        </a>
      </div>
    </div>
  </section>

  <!-- ── Dual audience section ── -->
  <section class="py-28 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text); letter-spacing: -0.02em;">Who uses Lagos?</h2>
        <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-muted);">
          Two very different people. One tool that works for both.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Accessibility card -->
        <div
          class="rounded-2xl border p-8"
          style="background-color: var(--color-surface); border-color: var(--color-border); box-shadow: 0 2px 8px 0 rgba(0,0,0,0.06);"
        >
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-6"
            style="background-color: #d1fae5; color: #059669;"
            aria-hidden="true"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="currentColor" stroke-width="1.75" fill="none"/>
              <path d="M8 12l3 3 5-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3" style="color: var(--color-text);">For accessibility needs</h3>
          <p class="leading-relaxed mb-6" style="color: var(--color-text-muted);">
            RSI, carpal tunnel, motor impairments, fatigue — Lagos gives you a friction-free way to type without typing. Talk at your natural pace and let Lagos handle the rest.
          </p>
          <ul class="space-y-3" aria-label="Accessibility features">
            {[
              'Works in any text field, any app, system-wide',
              'No hand movement required after shortcut press',
              'Customizable modifier keys to match your setup',
              'Optional floating recording indicator',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm" style="color: var(--color-text-muted);">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0 mt-0.5" aria-hidden="true">
                  <path d="M3 8l3.5 3.5L13 5" stroke="#059669" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Developer card -->
        <div
          class="rounded-2xl border p-8"
          style="background-color: var(--color-surface); border-color: var(--color-border); box-shadow: 0 2px 8px 0 rgba(0,0,0,0.06);"
        >
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-6"
            style="background-color: #fef3c7; color: #d97706;"
            aria-hidden="true"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M8 9l-3 3 3 3M16 9l3 3-3 3M14 4l-4 16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3" style="color: var(--color-text);">For developers & creators</h3>
          <p class="leading-relaxed mb-6" style="color: var(--color-text-muted);">
            Dictate prompts to AI coding assistants, narrate commit messages, jot notes mid-flow — without breaking your keyboard momentum. Think it, say it, done.
          </p>
          <ul class="space-y-3" aria-label="Developer features">
            {[
              'AI cleanup removes filler words and fixes grammar',
              'Full transcription history with full-text search',
              'Works with Cursor, VS Code, Claude, ChatGPT',
              'BYOK for full control over quality and cost',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm" style="color: var(--color-text-muted);">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="shrink-0 mt-0.5" aria-hidden="true">
                  <path d="M3 8l3.5 3.5L13 5" stroke="#d97706" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Download CTA ── -->
  <section
    class="py-28 px-4 sm:px-6 lg:px-8"
    style="background: linear-gradient(135deg, var(--color-warm-900) 0%, #2d2621 100%);"
    id="download"
  >
    <div class="mx-auto max-w-2xl text-center">
      <h2
        class="text-4xl sm:text-5xl font-bold mb-5 leading-tight"
        style="color: var(--color-warm-50); letter-spacing: -0.02em;"
      >
        Start talking,<br/>stop typing.
      </h2>
      <p class="text-lg mb-10" style="color: var(--color-warm-400);">
        Free forever. No account, no subscription, no catch.
      </p>
      <div class="flex justify-center">
        <EmailGatedDownload size="lg" theme="dark" />
      </div>
    </div>
  </section>

  <!-- ── Beta signup ── -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-lg text-center">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold mb-4"
        style="background-color: rgba(16,185,129,0.1); color: #059669;"
      >
        <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background-color: #10b981;" aria-hidden="true"></span>
        Limited time offer
      </div>
      <h2 class="text-2xl font-bold mb-2" style="color: var(--color-text); letter-spacing: -0.02em;">
        Join the beta — get 2 years of Pro free
      </h2>
      <p class="text-sm mb-8" style="color: var(--color-text-muted);">
        Everyone who joins the beta before March 31, 2026 gets Lagos Pro free for 2 years when it launches. No credit card required.
      </p>
      <NewsletterForm type="waitlist" buttonText="Join the beta" />
    </div>
  </section>

</BaseLayout>
